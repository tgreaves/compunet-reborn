# Compunet Reborn Configuration
# Copy this file to .env and set your values

# API key for the user management REST API (shared between server and website)
COMPUNET_API_KEY=changeme

# Postmark API key for transactional email (verification, password reset)
POSTMARK_API_KEY=changeme

# Flask secret key for session cookies
WEBSITE_SECRET_KEY=changeme

# Public URL of the website (used in verification email links)
WEBSITE_BASE_URL=https://dev.compunet.live

# From address for outgoing emails
EMAIL_FROM=noreply@compunet.live
