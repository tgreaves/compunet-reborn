E082A   =$082AF0800   =$0800A01     =$01A2D     =$2DA2E     =$2EAFC     =$FCAFD     =$FDAFF     =$FFPFC     =$FC;       LDX #$01I0102  LDA (PFC),YI0104  INC AFC       BNE I010A       INC AFDI010A  CMP #$7F       BEQ I012CA0110  =*+02I010E  STA F0800,X       INX       BNE I0117       INC A0110I0117  LDA AFC       ORA AFD       BNE I0102       STX A2D       LDA A0110       STA A2E       LDA #$36       STA A01       CLI       JMP E082AI012C  LDA (PFC),Y       INC AFC       BNE I0134       INC AFDI0134  CMP #$00       BNE I013C       LDA #$7F       BNE I010EI013C  STA AFF       LDA (PFC),Y       LDY A0110       STY A014E       LDY AFF       INYI0149  DEY       BEQ I0104A014E  =*+02       STA F0800,X       INX       BNE I0149       INC A0110       INC A014E       BNE I0149       BRK;